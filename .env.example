# =============================================================================
# Example environment for the portfolio site.
# Copy to .env.local and fill in real values:   cp .env.example .env.local
# Or pull the real set from Vercel:             vercel env pull .env.local
# NEVER commit .env.local — only this .env.example (placeholders only) is tracked.
# =============================================================================

# ---- AI chat provider -------------------------------------------------------
# Which provider the /api/chat route uses: anthropic | openai | gemini.
# Unset => anthropic.
AI_PROVIDER=anthropic

# Anthropic (default provider)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional. Default: claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI (used when AI_PROVIDER=openai)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional. Default: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (used when AI_PROVIDER=gemini)
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional Gemini model id
GEMINI_MODEL=

# Kill switch: set to "false" to disable the chat route entirely. Any other value = enabled.
CHAT_ENABLED=true

# ---- System prompt (fetched at runtime) -------------------------------------
# Raw URLs (e.g. gist raw links). SYSTEM_PROMPT_URL = behavior, PERSONA_URL = bio.
# Either/both optional; falls back to FALLBACK_PROMPT in lib/system-prompt.ts when unset.
SYSTEM_PROMPT_URL=
PERSONA_URL=

# ---- Rate limiting (Upstash Redis REST) -------------------------------------
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Google Calendar (service account) --------------------------------------
# Service-account JSON fields. GOOGLE_PRIVATE_KEY keeps newlines as literal \n.
GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_CLIENT_EMAIL=portfolio-bot@your-project.iam.gserviceaccount.com
# Preferred: base64 of the raw PEM. No quote/newline fragility, so it survives
# any env-var host. When set it WINS over GOOGLE_PRIVATE_KEY. Generate with:
#   node -e "process.stdout.write(Buffer.from(require('fs').readFileSync('key.pem')).toString('base64'))" | pbcopy
GOOGLE_PRIVATE_KEY_B64=
# Fallback raw PEM. A wrapping-quoted value works locally but can fail on some
# hosts (ERR_OSSL_UNSUPPORTED); the loader strips the quotes defensively.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...REPLACE_ME...\n-----END PRIVATE KEY-----\n"
# Both calendars are read and merged for busy/free. Personal is also the booking write target.
GOOGLE_CALENDAR_ID_PERSONAL=you@gmail.com
GOOGLE_CALENDAR_ID_WORK=you@work-domain.com
# Optional static Google Meet link added to booking events. Leave empty to omit.
MEET_URL=

# ---- OAuth admin sign-in (Auth.js / NextAuth) -------------------------------
# Session/JWT secret. Generate with:  openssl rand -base64 32
AUTH_SECRET=replace-with-random-32-byte-base64
# Google OAuth app credentials (admin booking access).
OAUTH_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
OAUTH_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
